<?php

declare(strict_types=1);

/**
 * @file
 * Admor site hooks.
 */

/**
 * Implements hook_theme().
 */
function admor_site_theme($existing, $type, $theme, $path): array {
  return [
    'admor_site_hero_block' => [
      'variables' => ['items' => [], 'theme_path' => NULL],
      'template' => 'admor-site-hero-block',
    ],
    'admor_site_cta_block' => [
      'variables' => [],
      'template' => 'admor-site-cta-block',
    ],
    'admor_site_categories_block' => [
      'variables' => ['items' => []],
      'template' => 'admor-site-categories-block',
    ],
    'admor_site_teaser_block' => [
      'variables' => [
        'eyebrow' => NULL,
        'heading' => NULL,
        'lead' => NULL,
        'items' => [],
        'empty_text' => NULL,
        'link_text' => NULL,
      ],
      'template' => 'admor-site-teaser-block',
    ],
    'admor_site_staff_block' => [
      'variables' => ['groups' => [], 'theme_path' => NULL],
      'template' => 'admor-site-staff-block',
    ],
    'admor_site_testimonials_block' => [
      'variables' => ['items' => []],
      'template' => 'admor-site-testimonials-block',
    ],
    'admor_site_videos_block' => [
      'variables' => ['items' => []],
      'template' => 'admor-site-videos-block',
    ],
  ];
}

/**
 * Implements hook_preprocess_page().
 */
function admor_site_preprocess_page(array &$variables): void {
  $resolver = \Drupal::service('admor_site.content_resolver');
  $variables['admor_main_menu'] = $resolver->buildMainMenu();
  $variables['admor_footer_menu'] = $resolver->buildMainMenu();
  $variables['admor_contact'] = $resolver->buildContact();

  if (\Drupal::service('path.matcher')->isFrontPage()) {
    $variables['admor_home'] = $resolver->buildHomepage();
  }
}
